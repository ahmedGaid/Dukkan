rules_version = '2';

// Dukkan Firestore security rules — v1 (F3 users + C1 shops/products + C4 orders).
// Deploy: Firebase console → Firestore Database → Rules → paste → Publish
// (the CLI `firebase deploy` path needs an interactive login we can't run here).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A user owns exactly their own /users/{uid} profile.
    match /users/{userId} {
      allow read: if isSelf(userId);

      allow create: if isSelf(userId)
        && request.resource.data.role in ['customer', 'owner']
        && request.resource.data.name is string
        && request.resource.data.email is string;

      // Profile edits allowed, but the role is fixed once chosen at signup.
      allow update: if isSelf(userId)
        && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    // Catalog is public to read (browsing works signed-out); writes just need
    // an authenticated user for now — tightened to owner-only in S1/S2 once
    // shop ownership is assigned at signup.
    match /shops/{shopId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // A customer owns their own orders; a shop owner can read orders placed
    // against their own shop (needed once S3's order desk lands).
    match /orders/{orderId} {
      function isOrderOwner() {
        return isSelf(resource.data.customerUid);
      }
      function isShopOwner() {
        return isSignedIn() &&
          get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerUid
            == request.auth.uid;
      }

      allow read: if isOrderOwner() || isShopOwner();

      allow create: if isSelf(request.resource.data.customerUid);

      // Only mutation today is a customer cancelling their own pending/
      // accepted order (CancelOrder) — status-only change. Shop-owner status
      // advances (accept/reject/preparing/...) land with S3 and extend this.
      allow update: if isOrderOwner()
        && resource.data.status in ['pending', 'accepted']
        && request.resource.data.status == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      allow delete: if false;
    }

    // Deny anything without an explicit rule above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
