rules_version = '2';

// Dukkan Firestore security rules — v1 (F3 users + C1 shops/products + C4 orders).
// Deploy: Firebase console → Firestore Database → Rules → paste → Publish
// (the CLI `firebase deploy` path needs an interactive login we can't run here).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // RBAC (Founder Console session 1). /admins/{uid} carries a FLAT
    // `permissions` array — the Worker denormalizes role permissions + extras
    // into it on every change, so rules do exactly one get() here. hasPerm is
    // deliberately auth-only (never resource.data) so aggregate queries stay
    // legal (M13 lesson).
    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }
    function isStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function hasPerm(p) {
      return isStaff() && adminDoc().isActive == true
        && adminDoc().permissions.hasAny([p, '*']);
    }

    // A user owns exactly their own /users/{uid} profile.
    match /users/{userId} {
      allow read: if isSelf(userId) || hasPerm('users.read');

      allow create: if isSelf(userId)
        && request.resource.data.role in ['customer', 'owner', 'courier']
        && request.resource.data.name is string
        && request.resource.data.email is string;

      // Profile edits allowed, but the role is fixed once chosen at signup —
      // OR staff with `users.update` may touch a narrow admin-op field set
      // (Founder Console session 6). Role/email changes stay Worker-only
      // (identity-linked; the Worker also updates Firebase Auth in step).
      allow update: if (isSelf(userId)
          && request.resource.data.role == resource.data.role)
        || (hasPerm('users.update')
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'phone', 'status', 'deleted', 'deletedAt', 'deletedBy']));

      allow delete: if false;
    }

    // Catalog is public to read (browsing works signed-out). Writes are
    // owner-only (S1b): a shop can only be created with the caller as its
    // own ownerUid, and only that owner can ever update it again.
    match /shops/{shopId} {
      allow read: if true;

      allow create: if (isSignedIn()
          && request.resource.data.ownerUid == request.auth.uid)
        // Founder Console creates a shop for a named owner (FC7) — no
        // self-ownerUid requirement, since the caller isn't the owner.
        || hasPerm('shops.update');

      // A rating bump (P3, RateOrder) touches only ratingSum/ratingCount, by
      // exactly one 1-5 star vote — any signed-in customer can do this (not
      // just the owner), since it rides on their own delivered order.
      function isValidRatingBump() {
        let bump = request.resource.data.ratingSum - resource.data.get('ratingSum', 0);
        return isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingSum', 'ratingCount'])
          && request.resource.data.ratingCount == resource.data.get('ratingCount', 0) + 1
          && bump >= 1 && bump <= 5;
      }

      allow update: if (isSignedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid)
        || isValidRatingBump()
        // Founder Console (FC7): status/flags/edits, never ownerUid — an
        // ownership change is the Worker's job only
        // (`/admin/shops/transfer`), which bypasses rules entirely.
        || (hasPerm('shops.update')
          && request.resource.data.ownerUid == resource.data.ownerUid);

      allow delete: if false;

      // Owner-curated collections (M6). Read is any signed-in user (customers
      // see them on the shop page); writes are the shop's own owner only —
      // same check as the parent `/shops/{shopId}` update rule. Console staff
      // (FC7) get the same write access as the owner, gated by `shops.update`.
      // Deleting a collection does NOT touch products; stale `collectionIds`
      // entries on product docs are ignored at render time.
      match /collections/{collectionId} {
        function ownsThisShop() {
          return isSignedIn() &&
            get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid
              == request.auth.uid;
        }

        allow read: if isSignedIn();
        allow create, update, delete: if ownsThisShop() || hasPerm('shops.update');
      }
    }

    // Catalog products (S2): only the owner of the product's own shop can
    // create/update/delete it, and a product can't be reassigned to another
    // shop after creation. Founder Console staff (FC8) get the same access,
    // gated by the `products.*` perms — never a shopId reassignment either.
    match /products/{productId} {
      function ownsShop(shopId) {
        return isSignedIn() &&
          get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid
            == request.auth.uid;
      }

      allow read: if true;

      allow create: if ownsShop(request.resource.data.shopId) || hasPerm('products.create');

      allow update: if (ownsShop(resource.data.shopId) || hasPerm('products.update'))
        && request.resource.data.shopId == resource.data.shopId;

      // Hard delete stays possible for owners as today; the console UI uses
      // soft delete (an `update` writing `deleted`/`deletedAt`/`deletedBy`)
      // except an explicit founder-only "delete forever" on an already
      // soft-deleted doc, which lands here.
      allow delete: if ownsShop(resource.data.shopId) || hasPerm('products.delete');
    }

    // A customer owns their own orders; a shop owner can read orders placed
    // against their own shop (needed once S3's order desk lands).
    match /orders/{orderId} {
      function isOrderOwner() {
        return isSelf(resource.data.customerUid);
      }
      function isShopOwner() {
        return isSignedIn() &&
          get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerUid
            == request.auth.uid;
      }
      function isAssignedDriver() {
        return isSignedIn() && resource.data.driverUid == request.auth.uid;
      }

      // Courier's own two-step handoff (M10): pick up (preparing ->
      // outForDelivery), then deliver (outForDelivery -> delivered) — the
      // only transitions the courier shell offers.
      function isValidDriverTransition() {
        let from = resource.data.status;
        let to = request.resource.data.status;
        return (from == 'preparing' && to == 'outForDelivery')
          || (from == 'outForDelivery' && to == 'delivered');
      }

      // Shop-owner status advances (S3): each `from -> to` pair below is the
      // only next step the order desk offers (order_status_view.dart's
      // orderPrimaryAction/orderSecondaryAction) — reject only from pending.
      function isValidOwnerTransition() {
        let from = resource.data.status;
        let to = request.resource.data.status;
        return (from == 'pending' && (to == 'accepted' || to == 'rejected'))
          || (from == 'accepted' && to == 'preparing')
          || (from == 'preparing' && to == 'outForDelivery')
          || (from == 'outForDelivery' && to == 'delivered');
      }

      // A status write that also flips `commissionPayable` to true is only
      // valid alongside a transition into `delivered` (M12 Task D) — the
      // owner or the assigned driver can both reach `delivered`, so both
      // transition branches below reuse this instead of the plain
      // status/statusHistory-only key set.
      function isDeliveredCommissionFlip() {
        return request.resource.data.status == 'delivered'
          && request.resource.data.commissionPayable == true
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'statusHistory', 'commissionPayable']);
      }

      // Founder finance summary (M13) — cross-shop count()/aggregate() reads
      // over the whole collection. The uid is kept literal here (rules can't
      // cheaply read `/config` docs) and mirrors the app-side
      // `AppConfig.founderUid` const; both are the one place this uid
      // appears until a real admin-role system exists. Deliberately
      // resource.data-independent: Firestore only allows an aggregation
      // query when the rule can be satisfied WITHOUT reading per-document
      // data, so this branch must never reference `resource.data` or the
      // founder's aggregate queries will be rejected outright.
      function isFounder() {
        return isSignedIn() && request.auth.uid == 'LPPjx32MJpWlMR3SEksJ7sY2NAF2';
      }

      allow read: if isFounder() || hasPerm('orders.read')
        || isOrderOwner() || isShopOwner() || isAssignedDriver();

      allow create: if isSelf(request.resource.data.customerUid);

      // A customer cancelling their own pending/accepted order (CancelOrder),
      // or the shop owner advancing status (S3) — both status-only changes.
      // A customer rating their own delivered order once (P3, RateOrder) —
      // exactly one 1-5 star write, and only while unrated.
      function isValidRating() {
        return isOrderOwner()
          && resource.data.status == 'delivered'
          && !('rating' in resource.data)
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating']);
      }

      // Owner assigns a driver (M9): only while the order is still
      // accepted/preparing and unassigned, only the driver-block fields.
      function isValidDriverAssignment() {
        return isShopOwner()
          && resource.data.status in ['accepted', 'preparing']
          && !('driverUid' in resource.data)
          && request.resource.data.driverUid is string
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['driverUid', 'driverName', 'driverPhone', 'assignedAt']);
      }

      allow update: if (isOrderOwner()
          && resource.data.status in ['pending', 'accepted']
          && request.resource.data.status == 'cancelled'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory']))
        || (isShopOwner()
          && isValidOwnerTransition()
          && (isDeliveredCommissionFlip()
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory'])))
        || isValidRating()
        || isValidDriverAssignment()
        || (isAssignedDriver()
          && isValidDriverTransition()
          && (isDeliveredCommissionFlip()
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory'])));

      allow delete: if false;

      // Internal staff notes (FC10) — append-only; no client update/delete
      // path anywhere, console included.
      match /notes/{noteId} {
        allow read, create: if hasPerm('orders.update');
        allow update, delete: if false;
      }
    }

    // Taxonomy (M3, console-editable from FC9) — the console is now the write
    // path, gated by `taxonomy.edit`; the seed script only ever runs once
    // signed in as founder, so no relax-then-restore dance is needed anymore.
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if hasPerm('taxonomy.edit');
    }

    // Delivery districts (M8, console-editable from FC9) — same shape/rule as
    // `/categories`, gated by `geo.edit`.
    match /areas/{areaId} {
      allow read: if isSignedIn();
      allow create, update, delete: if hasPerm('geo.edit');
    }

    // Shared platform driver pool (M8). A driver reads/updates only their own
    // doc, and only `isOnline`/`name`/`phone` — `isSuspended`, `areaIds`,
    // `maxActiveOrders`, `activeOrdersCount` are founder/console-managed
    // (the same temporarily-relax-then-restore trick as `/areas` covers demo
    // seeding). Shop owners need read access for the assignment list (M9), so
    // read is any signed-in user rather than isSelf-only.
    match /drivers/{uid} {
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
        && request.resource.data.isSuspended == true
        && request.resource.data.activeOrdersCount == 0;

      // Assignment (M9) bumps activeOrdersCount by exactly +1 (owner assigns)
      // or -1 (order reaches a terminal status) — any signed-in user, since
      // rule language can't cheaply confirm "owner of the order's shop" from
      // here. Loose by design; a Worker endpoint is the future hardening path.
      function isValidActiveCountBump() {
        return isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeOrdersCount'])
          && (request.resource.data.activeOrdersCount == resource.data.activeOrdersCount + 1
            || request.resource.data.activeOrdersCount == resource.data.activeOrdersCount - 1);
      }

      allow update: if (isSelf(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['isOnline', 'name', 'phone']))
        || isValidActiveCountBump()
        || (hasPerm('drivers.manage')
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'isSuspended', 'suspendReason', 'areaIds', 'maxActiveOrders',
               'vehicleType', 'vehiclePlate', 'idDocUrl', 'isVerified',
               'name', 'phone']));

      allow delete: if false;
    }

    // Founder-managed commission/delivery-fee rates (M12) — single
    // `/config/platform` doc, read-only to clients; the founder edits via
    // console. Same shape/rule as `/categories`/`/areas`.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow update: if hasPerm('settings.edit');
      allow create, delete: if false;   // docs are seeded once, never removed
    }

    // Staff registry + role definitions (Founder Console session 1) —
    // Worker/seed-managed only. A staff member may read their own admin doc
    // (the app loads it at login); `admins.manage` may read all (the user
    // management screens). No client write path: the Worker denormalizes
    // permissions and writes these, so the client never does.
    match /admins/{uid} {
      allow read: if isSelf(uid) || hasPerm('admins.manage');
      allow write: if false;
    }
    match /roles/{roleId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // Immutable audit trail (Founder Console session 4). Immutable by
    // construction: ONLY the Worker writes (its service account bypasses rules),
    // so clients — including staff — can never create/update/delete an entry.
    // A `reported: true` entry was client-reported (best-effort) via
    // `POST /admin/audit`; `reported: false` means the op ran server-side.
    match /auditLogs/{entryId} {
      allow read: if hasPerm('auditlogs.read');
      allow write: if false;
    }

    // Notification center (Founder Console session 13). History is
    // Worker-written only (broadcast/direct send both go through
    // `/admin/notify/*`, same immutability shape as `/auditLogs`).
    // Templates are a small console convenience — Firestore-direct, no
    // Worker route needed, same shape as `/config`.
    match /notifications/{id} {
      allow read: if hasPerm('notifications.send');
      allow write: if false;
    }
    match /notificationTemplates/{id} {
      allow read, write: if hasPerm('notifications.send');
    }

    // Deny anything without an explicit rule above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
