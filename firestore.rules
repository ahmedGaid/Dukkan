rules_version = '2';

// Dukkan Firestore security rules — v1 (F3 users + C1 shops/products + C4 orders).
// Deploy: Firebase console → Firestore Database → Rules → paste → Publish
// (the CLI `firebase deploy` path needs an interactive login we can't run here).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A user owns exactly their own /users/{uid} profile.
    match /users/{userId} {
      allow read: if isSelf(userId);

      allow create: if isSelf(userId)
        && request.resource.data.role in ['customer', 'owner']
        && request.resource.data.name is string
        && request.resource.data.email is string;

      // Profile edits allowed, but the role is fixed once chosen at signup.
      allow update: if isSelf(userId)
        && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    // Catalog is public to read (browsing works signed-out). Writes are
    // owner-only (S1b): a shop can only be created with the caller as its
    // own ownerUid, and only that owner can ever update it again.
    match /shops/{shopId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      // A rating bump (P3, RateOrder) touches only ratingSum/ratingCount, by
      // exactly one 1-5 star vote — any signed-in customer can do this (not
      // just the owner), since it rides on their own delivered order.
      function isValidRatingBump() {
        let bump = request.resource.data.ratingSum - resource.data.get('ratingSum', 0);
        return isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingSum', 'ratingCount'])
          && request.resource.data.ratingCount == resource.data.get('ratingCount', 0) + 1
          && bump >= 1 && bump <= 5;
      }

      allow update: if (isSignedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid)
        || isValidRatingBump();

      allow delete: if false;
    }

    // Catalog products (S2): only the owner of the product's own shop can
    // create/update/delete it, and a product can't be reassigned to another
    // shop after creation.
    match /products/{productId} {
      function ownsShop(shopId) {
        return isSignedIn() &&
          get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid
            == request.auth.uid;
      }

      allow read: if true;

      allow create: if ownsShop(request.resource.data.shopId);

      allow update: if ownsShop(resource.data.shopId)
        && request.resource.data.shopId == resource.data.shopId;

      allow delete: if ownsShop(resource.data.shopId);
    }

    // A customer owns their own orders; a shop owner can read orders placed
    // against their own shop (needed once S3's order desk lands).
    match /orders/{orderId} {
      function isOrderOwner() {
        return isSelf(resource.data.customerUid);
      }
      function isShopOwner() {
        return isSignedIn() &&
          get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerUid
            == request.auth.uid;
      }

      // Shop-owner status advances (S3): each `from -> to` pair below is the
      // only next step the order desk offers (order_status_view.dart's
      // orderPrimaryAction/orderSecondaryAction) — reject only from pending.
      function isValidOwnerTransition() {
        let from = resource.data.status;
        let to = request.resource.data.status;
        return (from == 'pending' && (to == 'accepted' || to == 'rejected'))
          || (from == 'accepted' && to == 'preparing')
          || (from == 'preparing' && to == 'outForDelivery')
          || (from == 'outForDelivery' && to == 'delivered');
      }

      allow read: if isOrderOwner() || isShopOwner();

      allow create: if isSelf(request.resource.data.customerUid);

      // A customer cancelling their own pending/accepted order (CancelOrder),
      // or the shop owner advancing status (S3) — both status-only changes.
      // A customer rating their own delivered order once (P3, RateOrder) —
      // exactly one 1-5 star write, and only while unrated.
      function isValidRating() {
        return isOrderOwner()
          && resource.data.status == 'delivered'
          && !('rating' in resource.data)
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating']);
      }

      allow update: if (isOrderOwner()
          && resource.data.status in ['pending', 'accepted']
          && request.resource.data.status == 'cancelled'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        || (isShopOwner()
          && isValidOwnerTransition()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        || isValidRating();

      allow delete: if false;
    }

    // Deny anything without an explicit rule above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
