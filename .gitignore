# Flutter/Dart (full set arrives with `flutter create` in session F1)
build/
.dart_tool/
.packages
pubspec.lock.bak
*.iml
.idea/
.vscode/

# Firebase secrets — never commit
google-services.json
GoogleService-Info.plist
firebase_options.dart
.env

# Android release signing — never commit the keystore or its passwords
android/key.properties
*.jks
*.keystore

# Local build tooling dropped at repo root — not part of the project
jdk-17.0.11_windows-x64_bin/
platform-tools/

# Machine-specific plugin path cache (regenerated by pub get)
.flutter-plugins-dependencies
